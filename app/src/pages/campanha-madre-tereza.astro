---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Campanha Madre Tereza de Calcutá - Em Defesa da Vida">
    <section class="py-24 px-4 bg-white min-h-screen">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16 flex flex-col items-center">
                <h1 class="text-4xl md:text-5xl font-bold mb-6 text-gray-800">Campanha Madre Tereza de Calcutá</h1>
                <p class="text-2xl text-brand-blue mb-8 font-medium">Em Defesa da Vida</p>
                <div class="bg-rose-50 border border-rose-100 p-8 rounded-2xl max-w-3xl text-left">
                    <p class="italic text-gray-700 leading-relaxed text-lg mb-4">
                        "344. Em que momento a alma se une ao corpo?<br><br>
                        A união começa na concepção, mas só é completa por ocasião do nascimento. Desde o instante da concepção, o Espírito designado para habitar certo corpo a este se liga por um laço fluídico, que cada vez mais se vai apertando até ao instante em que a criança vê a luz (...)"
                    </p>
                    <p class="text-gray-600 font-bold text-right">- Allan Kardec, O Livro dos Espíritos</p>
                </div>
            </div>

            <div class="grid md:grid-cols-2 gap-12 items-center mb-16">
                <div>
                    <h2 class="text-3xl font-bold mb-6 text-gray-800">A Campanha</h2>
                    <p class="text-gray-700 leading-relaxed mb-6 text-lg">
                        Tem como objetivo a conscientização da sociedade sobre a importância de valorizarmos a vida, protegendo o feto desde o momento da concepção. Nesta campanha são realizadas diversas atividades nas ruas, como distribuição de mensagens, palestras, fixação de faixas, doação de livros dentre outros.
                    </p>
                    <p class="text-gray-700 font-medium italic">
                        "Maternidade é a plenitude do coração feminino que norteia o progresso. Concepção, gravidez, parto e devoção afetiva representam estações difíceis e belas de um ministério divino."
                        <span class="block text-sm text-gray-500 font-normal mt-2">- André Luiz, O Espírito da Verdade</span>
                    </p>
                </div>
                <div>
                    <img src="https://gept.org.br/wp-content/uploads/2023/05/Carmpanha_madre_tereza_Cartaz.webp" alt="Cartaz Campanha Madre Tereza" class="rounded-2xl shadow-xl w-full object-cover">
                </div>
            </div>

            <div class="mb-16">
                <h2 class="text-3xl font-bold mb-6 text-gray-800">Assista ao Vídeo</h2>
                <div class="aspect-video rounded-2xl overflow-hidden shadow-2xl">
                    <iframe width="100%" height="100%" src="https://www.youtube.com/embed/TdotnORjDxU" title="Campanha Madre Tereza de Calcutá" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
                </div>
            </div>

            <!-- Materiais Section (Collapsible) -->
            <details class="bg-white border border-gray-200 rounded-2xl shadow-sm mb-16 group">
                <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-6 text-2xl text-gray-800 group-open:border-b border-gray-100">
                    Materiais para Divulgação
                    <span class="transition group-open:rotate-180 text-brand-blue">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                    </span>
                </summary>
                <div class="p-8 bg-gray-50 rounded-b-2xl">
                    <p class="text-gray-600 mb-8 text-center text-lg">Confira abaixo os materiais e panfletos utilizados durante a campanha:</p>
                    <div class="grid md:grid-cols-2 gap-8">
                        <img src="https://gept.org.br/wp-content/uploads/2023/05/mensagem_confia_e_segue.jpg" alt="Mensagem Confia e Segue" class="rounded-xl shadow-lg w-full hover:scale-105 transition duration-300">
                        <img src="https://gept.org.br/wp-content/uploads/2023/05/mensagem_em_defesa_da_vida.jpg" alt="Mensagem Em Defesa da Vida" class="rounded-xl shadow-lg w-full hover:scale-105 transition duration-300">
                    </div>
                </div>
            </details>

            <!-- Músicas Section -->
            <div class="mb-12">
                <h2 class="text-3xl font-bold mb-8 text-gray-800 text-center">Músicas da Campanha</h2>
                <div class="flex flex-col gap-4 max-w-3xl mx-auto">
                    <!-- Alegria de Viver -->
                    <div class="bg-rose-50 p-6 rounded-xl border border-rose-100 flex flex-col sm:flex-row items-center justify-between gap-4 shadow-sm hover:shadow-md transition">
                        <div class="flex items-center gap-4 w-full sm:w-auto">
                            <div class="bg-white p-3 rounded-full text-rose-500 shadow-sm flex-shrink-0">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"></path></svg>
                            </div>
                            <span class="font-bold text-gray-800 text-lg">Alegria de Viver</span>
                        </div>
                        <audio controls class="w-full sm:w-72 h-10 outline-none">
                            <source src="https://firebasestorage.googleapis.com/v0/b/gept-org-br.firebasestorage.app/o/audio%2FArtistas-diversos-ALEGRIA-DE-VIVER.mp3?alt=media" type="audio/mpeg">
                        </audio>
                    </div>
                    
                    <!-- Deixar Florescer -->
                    <div class="bg-rose-50 p-6 rounded-xl border border-rose-100 flex flex-col sm:flex-row items-center justify-between gap-4 shadow-sm hover:shadow-md transition">
                        <div class="flex items-center gap-4 w-full sm:w-auto">
                            <div class="bg-white p-3 rounded-full text-rose-500 shadow-sm flex-shrink-0">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"></path></svg>
                            </div>
                            <span class="font-bold text-gray-800 text-lg">Deixar Florescer</span>
                        </div>
                        <audio controls class="w-full sm:w-72 h-10 outline-none">
                            <source src="https://firebasestorage.googleapis.com/v0/b/gept-org-br.firebasestorage.app/o/audio%2FArtistas-diversos-DEIXAR-FLORESCER.mp3?alt=media" type="audio/mpeg">
                        </audio>
                    </div>
                    
                    <!-- São Chegados os Tempos -->
                    <div class="bg-rose-50 p-6 rounded-xl border border-rose-100 flex flex-col sm:flex-row items-center justify-between gap-4 shadow-sm hover:shadow-md transition">
                        <div class="flex items-center gap-4 w-full sm:w-auto">
                            <div class="bg-white p-3 rounded-full text-rose-500 shadow-sm flex-shrink-0">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"></path></svg>
                            </div>
                            <span class="font-bold text-gray-800 text-lg">São Chegados os Tempos</span>
                        </div>
                        <audio controls class="w-full sm:w-72 h-10 outline-none">
                            <source src="https://firebasestorage.googleapis.com/v0/b/gept-org-br.firebasestorage.app/o/audio%2FArtistas-diversos-SAO-CHEGADOS-OS-TEMPOS.mp3?alt=media" type="audio/mpeg">
                        </audio>
                    </div>
                    
                    <!-- Viver é Tão Bom -->
                    <div class="bg-rose-50 p-6 rounded-xl border border-rose-100 flex flex-col sm:flex-row items-center justify-between gap-4 shadow-sm hover:shadow-md transition">
                        <div class="flex items-center gap-4 w-full sm:w-auto">
                            <div class="bg-white p-3 rounded-full text-rose-500 shadow-sm flex-shrink-0">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"></path></svg>
                            </div>
                            <span class="font-bold text-gray-800 text-lg">Viver é Tão Bom</span>
                        </div>
                        <audio controls class="w-full sm:w-72 h-10 outline-none">
                            <source src="https://firebasestorage.googleapis.com/v0/b/gept-org-br.firebasestorage.app/o/audio%2FArtistas-diversos-VIVER-E-TAO-BOM.mp3?alt=media" type="audio/mpeg">
                        </audio>
                    </div>
                </div>
            </div>

            <!-- CTA -->
            <div class="mt-20 bg-gradient-to-br from-gray-900 to-gray-800 rounded-[3rem] p-12 md:p-16 text-center text-white shadow-2xl relative overflow-hidden">
                <div class="absolute inset-0 bg-brand-blue opacity-20 mix-blend-overlay"></div>
                <div class="relative z-10">
                    <h2 class="text-3xl md:text-5xl font-bold mb-6">Em Defesa da Vida!</h2>
                    <p class="text-lg md:text-xl text-white/90 mb-10 max-w-2xl mx-auto font-light leading-relaxed">
                        Junte-se a nós nesta nobre campanha de conscientização sobre a importância da vida. Venha participar conosco.
                    </p>
                    <button id="open-modal-btn" class="inline-flex items-center gap-3 px-10 py-5 bg-white text-gray-800 font-bold text-lg rounded-full hover:bg-gray-100 transition transform hover:-translate-y-1 hover:shadow-xl group">
                        Quero participar
                        <svg class="w-6 h-6 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                    </button>
                </div>
            </div>

        </div>
    </section>

    <!-- Modal Form -->
    <div id="campaign-modal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4 bg-gray-900/60 backdrop-blur-sm opacity-0 transition-opacity duration-300">
        <div class="bg-white rounded-3xl w-full max-w-lg shadow-2xl overflow-hidden transform scale-95 transition-transform duration-300 flex flex-col max-h-[90vh]">
            <div class="flex justify-between items-center p-6 border-b border-gray-100 bg-gray-50">
                <h3 class="text-xl font-bold text-gray-800">Inscrição na Campanha</h3>
                <button id="close-modal-btn" class="text-gray-400 hover:text-gray-600 transition p-2 rounded-full hover:bg-gray-200">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            
            <div class="p-6 overflow-y-auto">
                <form id="campaign-form" class="space-y-5">
                    <input type="hidden" id="campaign-type" name="type" value="MADRE_TEREZA">
                    
                    <div>
                        <label for="name" class="block text-sm font-semibold text-gray-700 mb-1">Nome Completo</label>
                        <input type="text" id="name" name="name" required minlength="3" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-brand-blue focus:border-brand-blue transition outline-none text-gray-700 bg-gray-50 focus:bg-white" placeholder="Seu nome completo">
                    </div>
                    
                    <div>
                        <label for="email" class="block text-sm font-semibold text-gray-700 mb-1">E-mail</label>
                        <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-brand-blue focus:border-brand-blue transition outline-none text-gray-700 bg-gray-50 focus:bg-white" placeholder="seu.email@exemplo.com">
                    </div>
                    
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label for="city" class="block text-sm font-semibold text-gray-700 mb-1">Cidade</label>
                            <input type="text" id="city" name="city" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-brand-blue focus:border-brand-blue transition outline-none text-gray-700 bg-gray-50 focus:bg-white" placeholder="Ex: Uberlândia">
                        </div>
                        <div>
                            <label for="state" class="block text-sm font-semibold text-gray-700 mb-1">Estado</label>
                            <select id="state" name="state" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-brand-blue focus:border-brand-blue transition outline-none text-gray-700 bg-gray-50 focus:bg-white">
                                <option value="" disabled selected>UF</option>
                                <option value="MG">MG</option>
                                <option value="SP">SP</option>
                                <option value="GO">GO</option>
                                <option value="RJ">RJ</option>
                                <option value="OUTRO">Outro</option>
                            </select>
                        </div>
                    </div>

                    <div>
                        <label for="whatsapp" class="block text-sm font-semibold text-gray-700 mb-1">WhatsApp</label>
                        <input type="tel" id="whatsapp" name="whatsapp" required pattern="[0-9 \-\(\)]+" minlength="10" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-brand-blue focus:border-brand-blue transition outline-none text-gray-700 bg-gray-50 focus:bg-white" placeholder="(00) 00000-0000" title="Por favor, inclua o DDD">
                    </div>

                    <div id="form-message" class="hidden text-sm font-semibold p-4 rounded-xl text-center"></div>

                    <button type="submit" id="submit-btn" class="w-full py-4 mt-2 bg-brand-blue text-white rounded-xl font-bold text-lg hover:bg-brand-blueDark transition shadow-lg flex justify-center items-center gap-2">
                        <span id="btn-text">Confirmar Inscrição</span>
                        <svg id="btn-spinner" class="w-5 h-5 animate-spin hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                    </button>
                </form>
            </div>
        </div>
    </div>

    <script>
        const openBtn = document.getElementById('open-modal-btn');
        const closeBtn = document.getElementById('close-modal-btn');
        const modal = document.getElementById('campaign-modal');
        const modalContent = modal.querySelector('div');
        const form = document.getElementById('campaign-form');
        const formMessage = document.getElementById('form-message');
        const submitBtn = document.getElementById('submit-btn');
        const btnText = document.getElementById('btn-text');
        const btnSpinner = document.getElementById('btn-spinner');

        function openModal() {
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            setTimeout(() => {
                modal.classList.remove('opacity-0');
                modal.classList.add('opacity-100');
                modalContent.classList.remove('scale-95');
                modalContent.classList.add('scale-100');
            }, 10);
        }

        function closeModal() {
            modal.classList.remove('opacity-100');
            modal.classList.add('opacity-0');
            modalContent.classList.remove('scale-100');
            modalContent.classList.add('scale-95');
            setTimeout(() => {
                modal.classList.remove('flex');
                modal.classList.add('hidden');
            }, 300);
        }

        openBtn.addEventListener('click', openModal);
        closeBtn.addEventListener('click', closeModal);
        modal.addEventListener('click', (e) => {
            if (e.target === modal) closeModal();
        });

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            submitBtn.disabled = true;
            btnText.textContent = 'Enviando...';
            btnSpinner.classList.remove('hidden');
            formMessage.classList.add('hidden');

            const formData = {
                name: document.getElementById('name').value,
                email: document.getElementById('email').value,
                city: document.getElementById('city').value,
                state: document.getElementById('state').value,
                whatsapp: document.getElementById('whatsapp').value,
                type: document.getElementById('campaign-type').value,
            };

            const isLocal = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';
            const API_URL = isLocal 
                ? 'http://127.0.0.1:5001/gept-org-br/us-east1/saveCampaignLeads'
                : 'https://us-east1-gept-org-br.cloudfunctions.net/saveCampaignLeads';

            try {
                const response = await fetch(API_URL, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(formData)
                });

                if (response.ok) {
                    formMessage.textContent = 'Inscrição confirmada com sucesso! Redirecionando para o WhatsApp...';
                    formMessage.className = 'p-4 rounded-xl text-center text-sm font-semibold bg-green-50 text-green-700 mt-6 block';
                    form.reset();
                    
                    setTimeout(() => {
                        window.open('https://chat.whatsapp.com/CaFqxPmcGa4HnwJm8aCWj0', '_blank');
                    }, 1500);
                } else {
                    const err = await response.json();
                    throw new Error(err.error || 'Erro ao enviar.');
                }
            } catch (error) {
                formMessage.textContent = error.message;
                formMessage.className = 'p-4 rounded-xl text-center text-sm font-semibold bg-red-50 text-red-600 mt-6 block';
            } finally {
                submitBtn.disabled = false;
                btnText.textContent = 'Confirmar Inscrição';
                btnSpinner.classList.add('hidden');
            }
        });
    </script>
</Layout>
