---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Evangelização Infantil">
    <!-- Hero Section -->
    <section class="relative pt-32 pb-24 px-4 overflow-hidden bg-brand-blue">
        <div class="absolute inset-0 z-0">
            <div class="absolute inset-0 bg-gradient-to-br from-brand-blue via-brand-blueDark to-blue-900 opacity-90"></div>
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.05)_1px,transparent_1px)] bg-[size:24px_24px]"></div>
        </div>
        
        <div class="max-w-6xl mx-auto relative z-10 flex flex-col md:flex-row items-center gap-12">
            <div class="w-32 h-32 md:w-48 md:h-48 rounded-full overflow-hidden border border-white/20 shadow-2xl flex-shrink-0 bg-white">
                <img src="/images/infancia.png" alt="Logo Evangelização Infantil" class="w-full h-full object-cover">
            </div>
            <div class="text-white text-center md:text-left">
                <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 rounded-full backdrop-blur-md mb-6 border border-white/20 text-sm font-semibold uppercase tracking-wide text-blue-100">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                    Instituto da Criança
                </div>
                <h1 class="text-4xl md:text-6xl font-bold mb-6 leading-tight drop-shadow-md">
                    Evangelização Infantil
                </h1>
                <p class="text-xl text-blue-100 max-w-3xl leading-relaxed font-light">
                    O sorriso do futuro na face do presente. Ajudando a criança sob a luz do Cristo.
                </p>
                <div class="mt-8 flex flex-wrap gap-4 justify-center md:justify-start">
                    <div class="flex items-center gap-3 bg-white/10 px-6 py-4 rounded-2xl backdrop-blur-sm border border-white/10">
                        <svg class="w-6 h-6 text-yellow-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        <span class="font-medium">👉🏾 Sábado - 9h10</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Main Content -->
    <section class="py-24 px-4 bg-gray-50">
        <div class="max-w-4xl mx-auto space-y-12">
            
            <!-- Visão e Objetivo -->
            <div class="mb-12">
                <div class="flex items-center gap-4 mb-8">
                    <div class="w-14 h-14 bg-blue-50 text-brand-blue rounded-2xl flex items-center justify-center flex-shrink-0">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
                    </div>
                    <h2 class="text-3xl font-bold text-gray-800">Nossa Escola</h2>
                </div>
                <p class="text-lg text-gray-700 leading-relaxed mb-6">
                    A Escola de Evangelização Espírita Infantil visa a implantação e organização do atendimento às crianças de 0 a 11 anos, bem como a <strong>Formação de Evangelizadores Espíritas para a Infância</strong>, preparando-os para a atuação nas atividades de evangelização infantil da Casa Espírita.
                </p>
                <p class="text-lg text-gray-700 leading-relaxed mb-10">
                    Sendo um Núcleo de Trabalho do Instituto da Criança, a metodologia tem como modelo as escolas de evangelização infantil do mundo espiritual, descritas nos livros de Francisco Cândido Xavier, como <em>Mensagem do Pequeno Morto</em>, <em>Escola do Além</em>, <em>Entre a Terra e o Céu</em> e <em>Voltei</em>.
                </p>
                
                <blockquote class="border-l-4 border-brand-blue bg-blue-50/50 p-8 rounded-r-2xl italic text-gray-800 text-lg shadow-inner">
                    "A Criança ainda é o sorriso do futuro na face do presente. Evangelizá-la é, pois, espiritualizar o porvir, legando-lhe a lição clara e pura do ensinamento cristão, a fim de que, verdadeiramente, viva o Cristo nas gerações de amanhã."
                    <footer class="mt-4 text-base font-bold text-brand-blue not-italic">— Francisco Spinelli</footer>
                </blockquote>
            </div>

            <!-- Importância -->
            <div class="mb-12">
                <div class="flex items-center gap-4 mb-8">
                    <div class="w-14 h-14 bg-blue-50 text-brand-blue rounded-2xl flex items-center justify-center flex-shrink-0">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path></svg>
                    </div>
                    <h2 class="text-3xl font-bold text-gray-800">A Importância da Evangelização</h2>
                </div>
                
                <blockquote class="border-l-4 border-brand-blue bg-blue-50/50 p-8 rounded-r-2xl italic text-gray-800 text-lg leading-relaxed shadow-inner mb-8">
                    "É possível a renovação do mundo em que habitamos, além da reforma interior de cada um para o bem, sem darmos à criança de hoje o embasamento evangélico? Sem a renovação espiritual da criatura para o bem, jamais chegaríamos ao nível superior que nos compete alcançar. Ajudar a criança, amparando-lhe o desenvolvimento, sob a luz do Cristo, é cooperar na construção da reforma santificante da humanidade, na direção do mundo redimido de amanhã."
                    <footer class="mt-4 text-base font-bold text-brand-blue not-italic">— Emmanuel (Encontros no Tempo, perg. 42)</footer>
                </blockquote>

                <h3 class="text-2xl font-bold text-gray-800 mt-10 mb-6">Por que o período infantil é o mais importante para a tarefa educativa?</h3>
                <div class="space-y-6 text-gray-700 leading-relaxed text-lg">
                    <p>
                        "Encarnando, com o objetivo de se aperfeiçoar, o Espírito, durante esse período, é mais acessível às impressões que recebe, capazes de lhe auxiliarem o adiantamento, para o que devem contribuir os incumbidos de educá-lo."
                        <span class="block text-sm font-semibold text-brand-blue mt-2">— Allan Kardec (O Livro dos Espíritos, perg. 383)</span>
                    </p>
                    <p>
                        "A delicadeza da idade infantil os torna brandos, acessíveis aos conselhos da experiência e dos que devam fazê-los progredir. Nessa fase é que se lhes pode reformar os caracteres e reprimir os maus pendores."
                        <span class="block text-sm font-semibold text-brand-blue mt-2">— Allan Kardec (O Livro dos Espíritos, perg. 385)</span>
                    </p>
                    <p>
                        "Até aos sete anos, o Espírito ainda se encontra em fase de adaptação para a nova existência que lhe compete no mundo... Suas recordações do plano espiritual são, por isso, mais vivas, tornando-se mais suscetível de renovar o caráter e estabelecer novo caminho."
                        <span class="block text-sm font-semibold text-brand-blue mt-2">— Emmanuel (O Consolador, perg. 109)</span>
                    </p>
                </div>
            </div>

            <!-- Horário e CTA -->
            <div class="grid md:grid-cols-2 gap-8">
                <div class="bg-brand-blue rounded-3xl p-10 shadow-xl shadow-blue-900/20 text-white flex flex-col justify-center">
                    <h3 class="text-2xl font-bold mb-4">Horários</h3>
                    <p class="text-blue-100 mb-6 text-lg">
                        As atividades de Evangelização Infantil (de 0 a 11 anos e 11 meses) ocorrem semanalmente.
                    </p>
                    <div class="bg-white/10 rounded-2xl p-6 border border-white/20">
                        <div class="flex items-center gap-4">
                            <svg class="w-8 h-8 text-yellow-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            <div>
                                <h4 class="font-bold text-xl">Sábados</h4>
                                <p class="text-blue-100">Das 09h10 às 11h40</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="bg-gradient-to-br from-gray-900 to-gray-800 rounded-[3rem] p-10 text-center text-white shadow-2xl relative overflow-hidden flex flex-col justify-center items-center">
                    <div class="absolute inset-0 bg-brand-blue opacity-20 mix-blend-overlay"></div>
                    <div class="relative z-10">
                        <h3 class="text-2xl font-bold mb-4">Venha nos conhecer</h3>
                        <p class="text-white/90 mb-8 font-light">
                            Proporcione aos seus pequenos uma base sólida de amor, fraternidade e ensinamentos cristãos.
                        </p>
                        <button id="open-modal-btn" class="inline-flex items-center gap-3 px-8 py-4 bg-white text-gray-800 font-bold rounded-full hover:bg-gray-100 transition transform hover:-translate-y-1 hover:shadow-xl group">
                            Quero matricular meu filho(a)
                            <svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </section>

    <!-- Modal Form -->
    <div id="campaign-modal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4 bg-gray-900/60 backdrop-blur-sm opacity-0 transition-opacity duration-300">
        <div class="bg-white rounded-3xl w-full max-w-lg shadow-2xl overflow-hidden transform scale-95 transition-transform duration-300 flex flex-col max-h-[90vh]">
            <div class="flex justify-between items-center p-6 border-b border-gray-100 bg-gray-50">
                <h3 class="text-xl font-bold text-gray-800">Inscrição na Evangelização</h3>
                <button id="close-modal-btn" class="text-gray-400 hover:text-gray-600 transition p-2 rounded-full hover:bg-gray-200">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            
            <div class="p-6 overflow-y-auto">
                <form id="campaign-form" class="space-y-5">
                    <input type="hidden" id="campaign-type" name="type" value="EVANGELIZACAO_INFANTIL">
                    
                    <div>
                        <label for="name" class="block text-sm font-semibold text-gray-700 mb-1">Nome do Responsável</label>
                        <input type="text" id="name" name="name" required minlength="3" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-brand-blue focus:border-brand-blue transition outline-none text-gray-700 bg-gray-50 focus:bg-white" placeholder="Seu nome completo">
                    </div>
                    
                    <div>
                        <label for="email" class="block text-sm font-semibold text-gray-700 mb-1">E-mail</label>
                        <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-brand-blue focus:border-brand-blue transition outline-none text-gray-700 bg-gray-50 focus:bg-white" placeholder="seu.email@exemplo.com">
                    </div>
                    
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label for="city" class="block text-sm font-semibold text-gray-700 mb-1">Cidade</label>
                            <input type="text" id="city" name="city" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-brand-blue focus:border-brand-blue transition outline-none text-gray-700 bg-gray-50 focus:bg-white" placeholder="Ex: Uberlândia">
                        </div>
                        <div>
                            <label for="state" class="block text-sm font-semibold text-gray-700 mb-1">Estado</label>
                            <select id="state" name="state" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-brand-blue focus:border-brand-blue transition outline-none text-gray-700 bg-gray-50 focus:bg-white">
                                <option value="" disabled selected>UF</option>
                                <option value="MG">MG</option>
                                <option value="SP">SP</option>
                                <option value="GO">GO</option>
                                <option value="RJ">RJ</option>
                                <option value="OUTRO">Outro</option>
                            </select>
                        </div>
                    </div>

                    <div>
                        <label for="whatsapp" class="block text-sm font-semibold text-gray-700 mb-1">WhatsApp</label>
                        <input type="tel" id="whatsapp" name="whatsapp" required pattern="[0-9 \-\(\)]+" minlength="10" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-brand-blue focus:border-brand-blue transition outline-none text-gray-700 bg-gray-50 focus:bg-white" placeholder="(00) 00000-0000" title="Por favor, inclua o DDD">
                    </div>

                    <div id="form-message" class="hidden text-sm font-semibold p-4 rounded-xl text-center"></div>

                    <button type="submit" id="submit-btn" class="w-full py-4 mt-2 bg-brand-blue text-white rounded-xl font-bold text-lg hover:bg-brand-blueDark transition shadow-lg flex justify-center items-center gap-2">
                        <span id="btn-text">Confirmar Inscrição</span>
                        <svg id="btn-spinner" class="w-5 h-5 animate-spin hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                    </button>
                </form>
            </div>
        </div>
    </div>

    <script>
        const openBtn = document.getElementById('open-modal-btn');
        const closeBtn = document.getElementById('close-modal-btn');
        const modal = document.getElementById('campaign-modal');
        const modalContent = modal.querySelector('div');
        const form = document.getElementById('campaign-form');
        const formMessage = document.getElementById('form-message');
        const submitBtn = document.getElementById('submit-btn');
        const btnText = document.getElementById('btn-text');
        const btnSpinner = document.getElementById('btn-spinner');

        function openModal() {
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            setTimeout(() => {
                modal.classList.remove('opacity-0');
                modal.classList.add('opacity-100');
                modalContent.classList.remove('scale-95');
                modalContent.classList.add('scale-100');
            }, 10);
        }

        function closeModal() {
            modal.classList.remove('opacity-100');
            modal.classList.add('opacity-0');
            modalContent.classList.remove('scale-100');
            modalContent.classList.add('scale-95');
            setTimeout(() => {
                modal.classList.remove('flex');
                modal.classList.add('hidden');
            }, 300);
        }

        openBtn.addEventListener('click', openModal);
        closeBtn.addEventListener('click', closeModal);
        modal.addEventListener('click', (e) => {
            if (e.target === modal) closeModal();
        });

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            submitBtn.disabled = true;
            btnText.textContent = 'Enviando...';
            btnSpinner.classList.remove('hidden');
            formMessage.classList.add('hidden');

            const formData = {
                name: document.getElementById('name').value,
                email: document.getElementById('email').value,
                city: document.getElementById('city').value,
                state: document.getElementById('state').value,
                whatsapp: document.getElementById('whatsapp').value,
                type: document.getElementById('campaign-type').value,
            };

            const isLocal = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';
            const API_URL = isLocal 
                ? 'http://127.0.0.1:5001/gept-org-br/us-east1/saveCampaignLeads'
                : 'https://us-east1-gept-org-br.cloudfunctions.net/saveCampaignLeads';

            try {
                const response = await fetch(API_URL, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(formData)
                });

                if (response.ok) {
                    formMessage.textContent = 'Inscrição confirmada com sucesso! Redirecionando para o WhatsApp...';
                    formMessage.className = 'p-4 rounded-xl text-center text-sm font-semibold bg-green-50 text-green-700 mt-6 block';
                    form.reset();
                    
                    setTimeout(() => {
                        window.open('https://chat.whatsapp.com/CaFqxPmcGa4HnwJm8aCWj0', '_blank');
                    }, 1500);
                } else {
                    const err = await response.json();
                    throw new Error(err.error || 'Erro ao enviar.');
                }
            } catch (error) {
                formMessage.textContent = error.message;
                formMessage.className = 'p-4 rounded-xl text-center text-sm font-semibold bg-red-50 text-red-600 mt-6 block';
            } finally {
                submitBtn.disabled = false;
                btnText.textContent = 'Confirmar Inscrição';
                btnSpinner.classList.add('hidden');
            }
        });
    </script>
</Layout>
