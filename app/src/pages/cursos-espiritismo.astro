---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Nossos Cursos">
    <section class="py-24 px-4 bg-gray-50 min-h-screen relative overflow-hidden">
        <!-- Background Elements -->
        <div class="absolute inset-0 z-0 bg-brand-blue opacity-5"></div>
        <div class="absolute top-[-10%] right-[-5%] w-96 h-96 bg-brand-blue rounded-full opacity-10 blur-3xl"></div>
        
        <div class="max-w-6xl mx-auto relative z-10">
            <div class="text-center mb-16">
                <div class="inline-flex items-center justify-center p-3 bg-blue-100 text-brand-blue rounded-2xl mb-6 shadow-sm">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                </div>
                <h1 class="text-4xl md:text-5xl font-bold mb-6 text-gray-800">Curso Conheça o Espiritismo</h1>
                <p class="text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed">
                    Nossos cursos de Doutrina Espírita têm o objetivo de trazer esclarecimentos luminosos sobre a vida e são totalmente gratuitos.
                </p>
            </div>

            <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-start">
                
                <!-- Support Text Section -->
                <div class="space-y-10">
                    <div>
                        <h2 class="text-3xl font-bold text-gray-800 mb-4">Para quem é este curso?</h2>
                        <p class="text-lg text-gray-700 leading-relaxed mb-4">
                            Às vezes a vida parece complexa e inexplicável. Por que pessoas morrem tão jovens? Por que precisamos passar por tanta dor e sofrimento? Qual é o sentido da vida?
                        </p>
                        <p class="text-lg text-gray-700 leading-relaxed">
                            Se você tem perguntas profundas e busca compreender mais sobre Deus, Jesus, a vida e sobre você mesmo, <strong>esse curso é para você</strong>.
                        </p>
                    </div>

                    <div class="bg-blue-50 border border-blue-100 rounded-2xl p-6 shadow-inner">
                        <h3 class="text-xl font-bold text-brand-blue mb-3">A Doutrina Espírita</h3>
                        <p class="text-gray-700 leading-relaxed">
                            O Espiritismo é uma Doutrina Cristã de natureza tríplice, abrangendo princípios <strong>filosóficos, científicos e religiosos</strong>. Ele nos traz explicações detalhadas sobre os ensinamentos do Cristo e as relações do mundo material com o plano espiritual.
                        </p>
                    </div>

                    <div>
                        <h2 class="text-2xl font-bold text-gray-800 mb-4">O que você irá aprender?</h2>
                        <p class="text-lg text-gray-700 leading-relaxed mb-4">
                            O curso é dividido em 4 semestres onde você irá aprender sobre a vida no plano espiritual, as curas de Jesus, e como empregar esses conhecimentos. Confira alguns dos temas do 1º semestre:
                        </p>
                        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                            <li class="flex items-center gap-2 text-gray-700 font-medium">
                                <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                Deus e Jesus
                            </li>
                            <li class="flex items-center gap-2 text-gray-700 font-medium">
                                <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                Reencarnação
                            </li>
                            <li class="flex items-center gap-2 text-gray-700 font-medium">
                                <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                Mediunidade
                            </li>
                            <li class="flex items-center gap-2 text-gray-700 font-medium">
                                <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                Lei de Causa e Efeito
                            </li>
                            <li class="flex items-center gap-2 text-gray-700 font-medium">
                                <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                Espírito e Períspirito
                            </li>
                            <li class="flex items-center gap-2 text-gray-700 font-medium">
                                <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                Pluralidade dos Mundos
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- Registration Form -->
                <div class="bg-white rounded-3xl p-8 md:p-10 shadow-xl shadow-gray-200/50 border border-gray-100 relative w-full">
                    <div class="absolute top-0 right-0 w-32 h-32 bg-brand-blue/5 rounded-bl-full rounded-tr-3xl"></div>
                    <h2 class="text-2xl font-bold mb-8 text-gray-800 text-center relative z-10">Formulário de Inscrição</h2>
                    
                    <form id="course-form" class="space-y-6 relative z-10">
                        <div>
                            <label for="name" class="block text-sm font-semibold text-gray-700 mb-2">Nome Completo</label>
                            <input type="text" id="name" name="name" required minlength="3" class="w-full px-5 py-3.5 rounded-xl border border-gray-200 focus:ring-2 focus:ring-brand-blue focus:border-brand-blue transition-all outline-none text-gray-700 placeholder-gray-400 bg-gray-50 focus:bg-white shadow-inner" placeholder="Seu nome completo" title="Por favor, insira pelo menos 3 caracteres.">
                        </div>
                        
                        <div>
                            <label for="email" class="block text-sm font-semibold text-gray-700 mb-2">E-mail</label>
                            <input type="email" id="email" name="email" required class="w-full px-5 py-3.5 rounded-xl border border-gray-200 focus:ring-2 focus:ring-brand-blue focus:border-brand-blue transition-all outline-none text-gray-700 placeholder-gray-400 bg-gray-50 focus:bg-white shadow-inner" placeholder="seu.email@exemplo.com">
                        </div>

                        <div class="grid md:grid-cols-2 gap-6">
                            <div>
                                <label for="city" class="block text-sm font-semibold text-gray-700 mb-2">Cidade</label>
                                <input type="text" id="city" name="city" required class="w-full px-5 py-3.5 rounded-xl border border-gray-200 focus:ring-2 focus:ring-brand-blue focus:border-brand-blue transition-all outline-none text-gray-700 placeholder-gray-400 bg-gray-50 focus:bg-white shadow-inner" placeholder="Sua cidade">
                            </div>
                            <div class="relative">
                                <label for="state" class="block text-sm font-semibold text-gray-700 mb-2">Estado</label>
                                <select id="state" name="state" required class="w-full px-5 py-3.5 rounded-xl border border-gray-200 focus:ring-2 focus:ring-brand-blue focus:border-brand-blue transition-all outline-none text-gray-700 bg-gray-50 focus:bg-white appearance-none shadow-inner cursor-pointer">
                                    <option value="" disabled selected>UF...</option>
                                    <option value="AC">Acre</option>
                                    <option value="AL">Alagoas</option>
                                    <option value="AP">Amapá</option>
                                    <option value="AM">Amazonas</option>
                                    <option value="BA">Bahia</option>
                                    <option value="CE">Ceará</option>
                                    <option value="DF">Distrito Federal</option>
                                    <option value="ES">Espírito Santo</option>
                                    <option value="GO">Goiás</option>
                                    <option value="MA">Maranhão</option>
                                    <option value="MT">Mato Grosso</option>
                                    <option value="MS">Mato Grosso do Sul</option>
                                    <option value="MG">Minas Gerais</option>
                                    <option value="PA">Pará</option>
                                    <option value="PB">Paraíba</option>
                                    <option value="PR">Paraná</option>
                                    <option value="PE">Pernambuco</option>
                                    <option value="PI">Piauí</option>
                                    <option value="RJ">Rio de Janeiro</option>
                                    <option value="RN">Rio Grande do Norte</option>
                                    <option value="RS">Rio Grande do Sul</option>
                                    <option value="RO">Rondônia</option>
                                    <option value="RR">Roraima</option>
                                    <option value="SC">Santa Catarina</option>
                                    <option value="SP">São Paulo</option>
                                    <option value="SE">Sergipe</option>
                                    <option value="TO">Tocantins</option>
                                </select>
                                <div class="absolute inset-y-0 right-0 flex items-center pr-4 pointer-events-none top-8">
                                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                </div>
                            </div>
                        </div>

                        <div>
                            <label for="whatsapp" class="block text-sm font-semibold text-gray-700 mb-2">WhatsApp</label>
                            <input type="tel" id="whatsapp" name="whatsapp" required pattern="[0-9 \-\(\)]+" minlength="10" class="w-full px-5 py-3.5 rounded-xl border border-gray-200 focus:ring-2 focus:ring-brand-blue focus:border-brand-blue transition-all outline-none text-gray-700 placeholder-gray-400 bg-gray-50 focus:bg-white shadow-inner" placeholder="(00) 00000-0000" title="Por favor, inclua o DDD. Ex: (34) 99999-9999">
                        </div>

                        <div class="pt-4">
                            <button id="submit-btn" type="submit" class="w-full py-4 bg-brand-blue text-white font-bold rounded-xl shadow-lg hover:shadow-brand-blue/30 hover:bg-brand-blueDark transition-all hover:-translate-y-0.5 transform duration-200 flex justify-center items-center gap-2 group">
                                <span id="btn-text">Enviar Inscrição</span>
                                <svg id="btn-icon" class="w-5 h-5 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                            </button>
                        </div>
                        
                        <div id="form-message" class="hidden mt-6"></div>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <script>
        const form = document.getElementById('course-form') as HTMLFormElement;
        const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
        const btnText = document.getElementById('btn-text');
        const btnIcon = document.getElementById('btn-icon');
        const formMessage = document.getElementById('form-message');

        if (form) {
            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                
                // Set loading state
                submitBtn.disabled = true;
                submitBtn.classList.add('opacity-75', 'cursor-not-allowed');
                btnText.textContent = 'Enviando...';
                btnIcon.classList.add('hidden');
                formMessage.classList.add('hidden');

                const formData = new FormData(form);
                const data = Object.fromEntries(formData.entries());

                const apiUrl = import.meta.env.DEV 
                    ? 'http://127.0.0.1:5001/gept-org-br/us-east1/saveCourseLead' 
                    : 'https://us-east1-gept-org-br.cloudfunctions.net/saveCourseLead';

                try {
                    const response = await fetch(apiUrl, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify(data),
                    });

                    if (response.ok) {
                        formMessage.textContent = 'Inscrição enviada com sucesso! Redirecionando para o grupo do WhatsApp...';
                        formMessage.className = 'p-4 rounded-xl text-center text-sm font-semibold bg-green-50 text-green-700 mt-6 block';
                        form.reset();
                        
                        // Open WhatsApp group in a new tab
                        setTimeout(() => {
                            window.open('https://chat.whatsapp.com/CaFqxPmcGa4HnwJm8aCWj0', '_blank');
                        }, 1000);
                    } else {
                        const err = await response.json();
                        throw new Error(err.error || 'Erro ao enviar.');
                    }
                } catch (error) {
                    console.error('Submission error:', error);
                    formMessage.textContent = 'Ocorreu um erro ao enviar sua inscrição. Tente novamente mais tarde.';
                    formMessage.className = 'p-4 rounded-xl text-center text-sm font-semibold bg-rose-50 text-rose-700 mt-6 block';
                } finally {
                    // Reset UI
                    submitBtn.disabled = false;
                    submitBtn.classList.remove('opacity-75', 'cursor-not-allowed');
                    btnText.textContent = 'Enviar Inscrição';
                    btnIcon.classList.remove('hidden');
                }
            });
        }
    </script>
</Layout>
