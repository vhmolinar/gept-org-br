---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Início">
    <!-- 1. Hero Section -->
    <section class="relative pt-12 md:pt-24 pb-12 md:pb-16 px-4 bg-gray-50 overflow-hidden">
        <div class="max-w-7xl mx-auto relative z-10 grid lg:grid-cols-2 gap-12 items-center">
            
            <!-- Left Column: Title + Carousel -->
            <div class="flex flex-col">
                <div class="text-center lg:text-left mb-8 md:mb-10 mt-2 md:mt-0">
                    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-4 leading-tight text-gray-800">
                        Grupo Espírita <br class="hidden lg:block" /> Paulo de Tarso
                    </h1>
                    <p class="text-xl md:text-2xl text-gray-500 font-light">
                        Deus, Cristo e Caridade
                    </p>
                </div>
                
                <!-- Boxed Carousel -->
                <div class="w-full aspect-video md:aspect-[16/9] bg-gray-900 rounded-[2.5rem] overflow-hidden shadow-2xl relative border border-gray-200" id="hero-carousel">
                    <!-- Slide 1 -->
                    <div class="carousel-slide absolute inset-0 transition-opacity duration-1000 opacity-100">
                        <div class="absolute inset-0 bg-cover bg-center blur-2xl opacity-50 scale-110" style="background-image: url('/images/activities/coral-escola.jpg');"></div>
                        <div class="absolute inset-0 bg-contain bg-no-repeat bg-center" style="background-image: url('/images/activities/coral-escola.jpg');"></div>
                    </div>
                    <!-- Slide 2 -->
                    <div class="carousel-slide absolute inset-0 transition-opacity duration-1000 opacity-0">
                        <div class="absolute inset-0 bg-cover bg-center blur-2xl opacity-50 scale-110" style="background-image: url('/images/activities/campanha-camilo-castelo-branco.png');"></div>
                        <div class="absolute inset-0 bg-contain bg-no-repeat bg-center" style="background-image: url('/images/activities/campanha-camilo-castelo-branco.png');"></div>
                    </div>
                    <!-- Slide 3 -->
                    <div class="carousel-slide absolute inset-0 transition-opacity duration-1000 opacity-0">
                        <div class="absolute inset-0 bg-cover bg-center blur-2xl opacity-50 scale-110" style="background-image: url('/images/activities/campanha-madre-tereza.png');"></div>
                        <div class="absolute inset-0 bg-contain bg-no-repeat bg-center" style="background-image: url('/images/activities/campanha-madre-tereza.png');"></div>
                    </div>
                    <!-- Slide 4 -->
                    <div class="carousel-slide absolute inset-0 transition-opacity duration-1000 opacity-0">
                        <div class="absolute inset-0 bg-cover bg-center blur-2xl opacity-50 scale-110" style="background-image: url('/images/activities/escola.jpg');"></div>
                        <div class="absolute inset-0 bg-contain bg-no-repeat bg-center" style="background-image: url('/images/activities/escola.jpg');"></div>
                    </div>
                    <!-- Slide 5 -->
                    <div class="carousel-slide absolute inset-0 transition-opacity duration-1000 opacity-0">
                        <div class="absolute inset-0 bg-cover bg-center blur-2xl opacity-50 scale-110" style="background-image: url('/images/activities/mocidade.jpeg');"></div>
                        <div class="absolute inset-0 bg-contain bg-no-repeat bg-center" style="background-image: url('/images/activities/mocidade.jpeg');"></div>
                    </div>
                    <!-- Slide 6 -->
                    <div class="carousel-slide absolute inset-0 transition-opacity duration-1000 opacity-0">
                        <div class="absolute inset-0 bg-cover bg-center blur-2xl opacity-50 scale-110" style="background-image: url('/images/activities/posto-euripedes.png');"></div>
                        <div class="absolute inset-0 bg-contain bg-no-repeat bg-center" style="background-image: url('/images/activities/posto-euripedes.png');"></div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Navigation Cards -->
            <div class="grid sm:grid-cols-2 gap-4 lg:gap-6 relative z-20">
                <!-- Nossos Cursos -->
                <a href="/cursos-espiritismo" class="group bg-white rounded-3xl p-6 shadow-xl shadow-gray-200/40 border border-gray-100 hover:-translate-y-1 hover:shadow-2xl transition-all duration-300 relative overflow-hidden flex flex-col h-full">
                    <div class="absolute top-0 right-0 w-24 h-24 bg-brand-blue/5 rounded-bl-[100px] transition-transform group-hover:scale-110"></div>
                    <div class="w-12 h-12 bg-blue-50 text-brand-blue rounded-2xl flex items-center justify-center mb-4 relative z-10">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                    </div>
                    <h3 class="text-xl font-bold text-gray-800 mb-2 group-hover:text-brand-blue transition-colors relative z-10">Nossos Cursos</h3>
                    <p class="text-gray-600 text-sm leading-relaxed flex-grow relative z-10">Conheça a Doutrina Espírita. Cursos gratuitos para trazer esclarecimentos luminosos sobre a vida.</p>
                </a>

                <!-- Tratamento Espiritual -->
                <a href="/tratamento-espiritual" class="group bg-white rounded-3xl p-6 shadow-xl shadow-gray-200/40 border border-gray-100 hover:-translate-y-1 hover:shadow-2xl transition-all duration-300 relative overflow-hidden flex flex-col h-full">
                    <div class="absolute top-0 right-0 w-24 h-24 bg-brand-blue/5 rounded-bl-[100px] transition-transform group-hover:scale-110"></div>
                    <div class="w-12 h-12 bg-blue-50 text-brand-blue rounded-2xl flex items-center justify-center mb-4 relative z-10">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
                    </div>
                    <h3 class="text-xl font-bold text-gray-800 mb-2 group-hover:text-brand-blue transition-colors relative z-10">Tratamento Espiritual</h3>
                    <p class="text-gray-600 text-sm leading-relaxed flex-grow relative z-10">Atendimento espiritual fraterno e passes de forma presencial e virtual (à distância).</p>
                </a>

                <!-- Evangelização Infantil -->
                <a href="/evangelizacao-infantil" class="group bg-white rounded-3xl p-6 shadow-xl shadow-gray-200/40 border border-gray-100 hover:-translate-y-1 hover:shadow-2xl transition-all duration-300 relative overflow-hidden flex flex-col h-full">
                    <div class="absolute top-0 right-0 w-24 h-24 bg-brand-blue/5 rounded-bl-[100px] transition-transform group-hover:scale-110"></div>
                    <div class="w-12 h-12 bg-blue-50 text-brand-blue rounded-2xl flex items-center justify-center mb-4 relative z-10">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <h3 class="text-xl font-bold text-gray-800 mb-2 group-hover:text-brand-blue transition-colors relative z-10">Evangelização Infantil</h3>
                    <p class="text-gray-600 text-sm leading-relaxed flex-grow relative z-10">Amparando o desenvolvimento da criança sob a luz do Cristo para o mundo de amanhã.</p>
                </a>

                <!-- Mocidade -->
                <a href="/mocidade" class="group bg-white rounded-3xl p-6 shadow-xl shadow-gray-200/40 border border-gray-100 hover:-translate-y-1 hover:shadow-2xl transition-all duration-300 relative overflow-hidden flex flex-col h-full">
                    <div class="absolute top-0 right-0 w-24 h-24 bg-brand-blue/5 rounded-bl-[100px] transition-transform group-hover:scale-110"></div>
                    <div class="w-12 h-12 bg-blue-50 text-brand-blue rounded-2xl flex items-center justify-center mb-4 relative z-10">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <h3 class="text-xl font-bold text-gray-800 mb-2 group-hover:text-brand-blue transition-colors relative z-10">Mocidade</h3>
                    <p class="text-gray-600 text-sm leading-relaxed flex-grow relative z-10">Núcleo voltado para jovens a partir de 12 anos. Confraternização, estudos doutrinários e ações no bem.</p>
                </a>
            </div>
        </div>
    </section>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const slides = document.querySelectorAll('.carousel-slide');
            if (slides.length === 0) return;
            let current = 0;
            setInterval(() => {
                slides[current].classList.replace('opacity-100', 'opacity-0');
                current = (current + 1) % slides.length;
                slides[current].classList.replace('opacity-0', 'opacity-100');
            }, 4000);
        });
    </script>

    <!-- Programação Section -->
    <section class="py-24 px-4 bg-gray-50">
        <div class="max-w-6xl mx-auto">
            <div class="text-center mb-16">
                <h2 class="text-3xl md:text-4xl font-bold mb-4 text-gray-800">Programação Semanal</h2>
                <p class="text-gray-600 max-w-xl mx-auto text-lg">Conheça nosso cronograma semanal de atividades.</p>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                <div class="bg-white border border-gray-100 p-8 rounded-3xl shadow-xl shadow-gray-200/40 hover:-translate-y-1 transition-transform">
                    <div class="text-brand-blue font-bold text-sm mb-3 uppercase tracking-wider">Segunda-feira • 19h45</div>
                    <h3 class="text-xl font-bold mb-3 text-gray-800">Triagem Fraterna</h3>
                    <p class="text-gray-600 text-sm leading-relaxed">Acolhimento e orientação para quem busca tratamento espiritual.</p>
                </div>
                <div class="bg-white border border-gray-100 p-8 rounded-3xl shadow-xl shadow-gray-200/40 hover:-translate-y-1 transition-transform">
                    <div class="text-brand-blue font-bold text-sm mb-3 uppercase tracking-wider">Terça-feira • 19h45</div>
                    <h3 class="text-xl font-bold mb-3 text-gray-800">Reunião Pública</h3>
                    <p class="text-gray-600 text-sm leading-relaxed">Palestras abertas e passes magnéticos (presencial e online).</p>
                </div>
                <div class="bg-white border border-gray-100 p-8 rounded-3xl shadow-xl shadow-gray-200/40 hover:-translate-y-1 transition-transform">
                    <div class="text-brand-blue font-bold text-sm mb-3 uppercase tracking-wider">Quarta-feira • 19h45</div>
                    <h3 class="text-xl font-bold mb-3 text-gray-800">Tratamento Espiritual</h3>
                    <p class="text-gray-600 text-sm leading-relaxed">Tratamento de desobsessão, evangelização e cura</p>
                </div>
                <div class="bg-white border border-gray-100 p-8 rounded-3xl shadow-xl shadow-gray-200/40 hover:-translate-y-1 transition-transform">
                    <div class="text-brand-blue font-bold text-sm mb-3 uppercase tracking-wider">Sábado • Manhã</div>
                    <h3 class="text-xl font-bold mb-3 text-gray-800">Evangelização e CECX</h3>
                    <ul class="text-gray-600 text-sm space-y-2">
                        <li><span class="font-medium text-gray-800">09h00:</span> Mocidade Espírita</li>
                        <li><span class="font-medium text-gray-800">09h10:</span> Evangelização Infantil</li>
                        <li><span class="font-medium text-gray-800">09h30:</span> Campanha de Esclarecimento Chico Xavier</li>
                    </ul>
                </div>
                <div class="bg-white border border-gray-100 p-8 rounded-3xl shadow-xl shadow-gray-200/40 hover:-translate-y-1 transition-transform">
                    <div class="text-brand-blue font-bold text-sm mb-3 uppercase tracking-wider">Sábado • 17h15</div>
                    <h3 class="text-xl font-bold mb-3 text-gray-800">Cursos Espiritismo</h3>
                    <p class="text-gray-600 text-sm leading-relaxed">Global Kardec (Estudos Sistematizados).</p>
                </div>
                <div class="bg-white border border-gray-100 p-8 rounded-3xl shadow-xl shadow-gray-200/40 hover:-translate-y-1 transition-transform">
                    <div class="text-brand-blue font-bold text-sm mb-3 uppercase tracking-wider">Domingo • Manhã</div>
                    <h3 class="text-xl font-bold mb-3 text-gray-800">Mocidade e CFAS</h3>
                    <ul class="text-gray-600 text-sm space-y-2">
                        <li><span class="font-medium text-gray-800">09h00:</span> Campanha de Fraternidade Auta de Souza</li>
                        <li><span class="font-medium text-gray-800">09h30:</span> Mocidade Espírita</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- 4. Volunteer/Donate CTA Section -->
    <section class="py-24 px-4 bg-brand-blue text-white relative overflow-hidden mt-12">
        <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 32px 32px;"></div>
        
        <div class="max-w-6xl mx-auto relative z-10">
            <div class="text-center mb-16">
                <h2 class="text-3xl md:text-5xl font-bold mb-6 text-white">Apoie nossas atividades sociais</h2>
                <p class="text-blue-100 max-w-2xl mx-auto text-lg">A manutenção da nossa casa e das obras sociais depende inteiramente da união e generosidade de nossos voluntários e doadores. Saiba como fazer a diferença.</p>
            </div>

            <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
                <!-- Campanha Auta de Souza Card -->
                <div class="bg-white text-gray-800 rounded-2xl p-8 hover-card shadow-2xl relative overflow-hidden flex flex-col justify-between">
                    <div>
                        <img src="/images/C.F.A.S-Logo.png" alt="CFAS" class="h-16 mb-4">
                        <h3 class="text-2xl font-bold mb-3">Campanha de Fraternidade Auta de Souza</h3>
                        <p class="text-gray-600 mb-6 text-sm leading-relaxed">Ajude-nos a levar consolo espiritual e alimento material de porta em porta. Saiba como ser um tarefeiro ou doador para as famílias carentes que assistimos.</p>
                    </div>
                    <a href="/campanha-auta-de-souza" class="inline-block text-center w-full py-3 bg-brand-blue text-white font-medium rounded-xl hover:bg-brand-blueDark transition">
                        Conheça o Projeto
                    </a>
                </div>

                <!-- Financial Donation Card -->
                <div class="bg-gray-900 text-white rounded-2xl p-8 hover-card shadow-2xl relative overflow-hidden">
                    <div class="absolute top-0 right-0 w-32 h-32 bg-brand-blue rounded-bl-full opacity-20"></div>
                    <div class="relative z-10">
                        <h3 class="text-2xl font-bold mb-3">Doação Financeira</h3>
                        <p class="text-gray-300 mb-8 text-sm">Sua contribuição ajuda a manter nossas portas abertas e sustenta nossos projetos de assistência social.</p>
                        
                        <div class="bg-gray-800 p-5 rounded-xl border border-gray-700 mb-4">
                            <div class="text-xs text-gray-400 uppercase tracking-wider mb-1 font-semibold">Chave PIX (Celular)</div>
                            <div class="text-lg font-mono font-bold text-white select-all">3499879-4774</div>
                        </div>
                        
                        <div class="text-xs text-gray-400 text-center">
                            Favorecido:<br>
                            <span class="font-semibold text-white text-sm">Lar Fabiano de Cristo</span><br>
                            (Obras sociais do Grupo Espírita Paulo de Tarso)
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>
