---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Programação Semanal">
    <section class="py-20 px-4 bg-white min-h-screen">
        <div class="max-w-6xl mx-auto">
            <div class="text-center mb-16">
                <h1 class="text-4xl md:text-5xl font-bold mb-4">Programação Semanal</h1>
                <p class="text-brand-muted max-w-xl mx-auto text-lg">Conheça nosso cronograma semanal de atividades.</p>
            </div>

            <h2 class="text-3xl font-bold mb-8 border-b pb-4">Programação Semanal</h2>
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-20">
                <div class="bg-gray-50 border border-gray-100 p-6 rounded-2xl hover-card">
                    <div class="text-brand-blue font-bold text-sm mb-2 uppercase">Segunda-feira • 19h45</div>
                    <h3 class="text-xl font-bold mb-2">Triagem Fraterna</h3>
                    <p class="text-gray-600 text-sm">Acolhimento e orientação para quem busca tratamento espiritual.</p>
                </div>
                <div class="bg-gray-50 border border-gray-100 p-6 rounded-2xl hover-card">
                    <div class="text-brand-blue font-bold text-sm mb-2 uppercase">Terça-feira • 19h45</div>
                    <h3 class="text-xl font-bold mb-2">Reunião Pública</h3>
                    <p class="text-gray-600 text-sm">Palestras abertas e passes magnéticos (presencial e online).</p>
                </div>
                <div class="bg-gray-50 border border-gray-100 p-6 rounded-2xl hover-card">
                    <div class="text-brand-blue font-bold text-sm mb-2 uppercase">Quarta-feira • 19h45</div>
                    <h3 class="text-xl font-bold mb-2">Tratamento Espiritual</h3>
                    <p class="text-gray-600 text-sm">Sessões agendadas de tratamento e passes específicos.</p>
                </div>
                <div class="bg-gray-50 border border-gray-100 p-6 rounded-2xl hover-card">
                    <div class="text-brand-blue font-bold text-sm mb-2 uppercase">Sábado • Manhã</div>
                    <h3 class="text-xl font-bold mb-3">Evangelização e CECX</h3>
                    <ul class="text-gray-600 text-sm space-y-2">
                        <li><span class="font-medium text-gray-800">09h00:</span> Mocidade Espírita</li>
                        <li><span class="font-medium text-gray-800">09h10:</span> Evangelização Infantil</li>
                        <li><span class="font-medium text-gray-800">09h30:</span> Camp. Esclarecimento Chico Xavier</li>
                    </ul>
                </div>
                <div class="bg-gray-50 border border-gray-100 p-6 rounded-2xl hover-card">
                    <div class="text-brand-blue font-bold text-sm mb-2 uppercase">Sábado • 17h15</div>
                    <h3 class="text-xl font-bold mb-3">Cursos Espiritismo</h3>
                    <p class="text-gray-600 text-sm">Global Kardec (Estudos Sistematizados).</p>
                </div>
                <div class="bg-gray-50 border border-gray-100 p-6 rounded-2xl hover-card">
                    <div class="text-brand-blue font-bold text-sm mb-2 uppercase">Domingo • Manhã</div>
                    <h3 class="text-xl font-bold mb-3">Assistência & Juventude</h3>
                    <ul class="text-gray-600 text-sm space-y-2">
                        <li><span class="font-medium text-gray-800">09h00:</span> Campanha Auta de Souza</li>
                        <li><span class="font-medium text-gray-800">09h30:</span> Mocidade Espírita</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>
</Layout>
