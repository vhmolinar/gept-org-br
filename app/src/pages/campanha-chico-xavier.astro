---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Campanha de Esclarecimento Chico Xavier">
    <!-- Hero Section -->
    <section class="relative pt-32 pb-24 px-4 overflow-hidden bg-brand-blue">
        <div class="absolute inset-0 z-0">
            <div class="absolute inset-0 bg-gradient-to-br from-brand-blue via-brand-blueDark to-blue-900 opacity-90"></div>
            <!-- Optional subtle pattern -->
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.05)_1px,transparent_1px)] bg-[size:24px_24px]"></div>
        </div>
        
        <div class="max-w-6xl mx-auto relative z-10 flex flex-col md:flex-row items-center gap-12">
            <div class="w-32 h-32 md:w-48 md:h-48 rounded-full overflow-hidden border border-white/20 shadow-2xl flex-shrink-0 bg-white flex items-center justify-center p-2">
                <img src="/images/cecx-logo.png" alt="Logo Campanha Chico Xavier" class="w-full h-full object-contain">
            </div>
            <div class="text-white text-center md:text-left">
                <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 rounded-full backdrop-blur-md mb-6 border border-white/20 text-sm font-semibold uppercase tracking-wide text-blue-100">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                    Instituto do Esclarecimento e Família
                </div>
                <h1 class="text-4xl md:text-6xl font-bold mb-6 leading-tight drop-shadow-md">
                    Campanha de Esclarecimento Chico Xavier
                </h1>
                <p class="text-xl text-blue-100 max-w-3xl leading-relaxed font-light">
                    Divulgação da Doutrina Espírita nos lares por meio do empréstimo de livros de estimado cunho moral.
                </p>
                <div class="mt-8 flex flex-wrap gap-4 justify-center md:justify-start">
                    <div class="flex items-center gap-3 bg-white/10 px-6 py-4 rounded-2xl backdrop-blur-sm border border-white/10">
                        <svg class="w-6 h-6 text-yellow-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        <span class="font-medium">👉🏾 Sábado - 9h30</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Main Content -->
    <section class="py-24 px-4 bg-gray-50">
        <div class="max-w-4xl mx-auto">
            
            <!-- O que é a Campanha -->
            <div class="mb-16">
                <div class="flex items-center gap-4 mb-8">
                    <div class="w-14 h-14 bg-blue-50 text-brand-blue rounded-2xl flex items-center justify-center flex-shrink-0">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <h2 class="text-3xl font-bold text-gray-800">O que é a Campanha?</h2>
                </div>
                <p class="text-lg text-gray-700 leading-relaxed mb-6">
                    A <strong>Campanha de Esclarecimento Chico Xavier</strong> tem por finalidade a divulgação da Doutrina Espírita nos lares (de porta em porta), por meio de empréstimo de livros Espíritas de estimado cunho moral.
                </p>
                <p class="text-lg text-gray-700 leading-relaxed mb-10">
                    Por outro lado, busca proporcionar ao caravaneiro a oportunidade do trabalho de difusão e consolo, esclarecimento e orientação, por intermédio do livro, e, portanto, exercitar a caridade.
                </p>
                
                <blockquote class="border-l-4 border-brand-blue bg-blue-50/50 p-8 rounded-r-2xl italic text-gray-800 text-lg shadow-inner">
                    "O Livro Espírita, penetrando todos os lares, da choupana ao palacete, conduzirá o Espírito Imortal ao 'conhecimento de si mesmo', à sua integral e definitiva libertação."
                    <footer class="mt-4 text-base font-bold text-brand-blue not-italic">— Francisco Thiesen, Reformador, 1972</footer>
                </blockquote>
            </div>

            <!-- Por que realizar a Campanha -->
            <div class="mb-16">
                <div class="flex items-center gap-4 mb-8">
                    <div class="w-14 h-14 bg-blue-50 text-brand-blue rounded-2xl flex items-center justify-center flex-shrink-0">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <h2 class="text-3xl font-bold text-gray-800">Por que realizar?</h2>
                </div>
                
                <blockquote class="border-l-4 border-brand-blue bg-blue-50/50 p-8 rounded-r-2xl italic text-gray-800 text-lg leading-relaxed shadow-inner">
                    "Hoje, o Consolador prometido traz ao mundo messes de esperanças, e o instrumento escolhido é o livro! Pelas mãos abençoadas de Allan Kardec, a Humanidade recebeu a mensagem divina para sua libertação e evolução espiritual. Livros e livros chegaram à Terra, como chuvas de bênçãos, enriquecendo o coração humano com as palavras de advertência, orientação e amor. Ensinos que se transformam em roteiros, caminhos que se enriquecem de almas emocionadas com a grande dádiva. A Humanidade terrena encontrará a sua estrada e verá surgir a paz e a concórdia num hino de amor e gratidão. Estudar, aprender, aplicar, praticar, vivenciar os ensinos é tornar-se partícipe dessa Divina Luz, vinda do Criador e orientada pelo Espírito de Verdade. […] Eis o Livro Espírita! Eis a Luz dos Céus à disposição do Homem! Eis o coração do Mestre Divino, palpitando no seio do Mundo!"
                    <footer class="mt-4 text-base font-bold text-brand-blue not-italic">— Bezerra de Menezes, Reformador, 1987</footer>
                </blockquote>
            </div>

            <!-- Roteiro de Funcionamento e Trabalho -->
            <div class="grid lg:grid-cols-2 gap-8 mb-12">
                <!-- Roteiro -->
                <div class="bg-brand-blue rounded-3xl p-10 shadow-xl shadow-blue-900/20 text-white relative overflow-hidden group">
                    <div class="absolute top-0 right-0 w-32 h-32 bg-white/5 rounded-bl-[100px] transition-transform duration-500 group-hover:scale-110"></div>
                    <h3 class="text-2xl font-bold mb-8 flex items-center gap-3 relative z-10">
                        <svg class="w-6 h-6 text-blue-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        Roteiro
                    </h3>
                    <ul class="space-y-5 relative z-10">
                        <li class="flex gap-4">
                            <span class="font-bold text-yellow-300 w-16 flex-shrink-0 pt-0.5">15 min</span>
                            <span class="text-white/95 leading-snug">Alegria cristã (músicas espíritas)</span>
                        </li>
                        <li class="flex gap-4">
                            <span class="font-bold text-yellow-300 w-16 flex-shrink-0 pt-0.5">5 min</span>
                            <span class="text-white/95 leading-snug">Leitura de "O Evangelho" e prece</span>
                        </li>
                        <li class="flex gap-4">
                            <span class="font-bold text-yellow-300 w-16 flex-shrink-0 pt-0.5">10 min</span>
                            <span class="text-white/95 leading-snug">Leitura de obra de Chico Xavier</span>
                        </li>
                        <li class="flex gap-4">
                            <span class="font-bold text-yellow-300 w-16 flex-shrink-0 pt-0.5">15 min</span>
                            <span class="text-white/95 leading-snug">Manual, divisão de duplas, entrega de material e avisos</span>
                        </li>
                        <li class="flex gap-4">
                            <span class="font-bold text-yellow-300 w-16 flex-shrink-0 pt-0.5">75 min</span>
                            <span class="text-white/95 leading-snug">Deslocamento e atividade de empréstimo</span>
                        </li>
                        <li class="flex gap-4">
                            <span class="font-bold text-yellow-300 w-16 flex-shrink-0 pt-0.5">10 min</span>
                            <span class="text-white/95 leading-snug">Avaliação</span>
                        </li>
                        <li class="flex gap-4">
                            <span class="font-bold text-yellow-300 w-16 flex-shrink-0 pt-0.5">5 min</span>
                            <span class="text-white/95 leading-snug">Encerramento e prece final</span>
                        </li>
                    </ul>
                </div>

                <!-- Setor de Trabalho -->
                <div class="space-y-6 flex flex-col justify-center">
                    <div class="bg-white rounded-3xl p-8 shadow-sm border border-gray-100 hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1">
                        <div class="flex items-center gap-4 mb-4">
                            <div class="w-10 h-10 rounded-full bg-green-100 text-green-600 flex items-center justify-center font-bold text-lg flex-shrink-0">1</div>
                            <h3 class="text-xl font-bold text-gray-800">Oferta de Livro</h3>
                        </div>
                        <p class="text-gray-600 text-sm md:text-base leading-relaxed">
                            Ofertar o Livro Espírita, preenchendo a Ficha de Empréstimo. A devolução ocorre após 14 dias. Entregamos uma carta explicativa e lemos uma mensagem espírita ao final.
                        </p>
                    </div>

                    <div class="bg-white rounded-3xl p-8 shadow-sm border border-gray-100 hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1">
                        <div class="flex items-center gap-4 mb-4">
                            <div class="w-10 h-10 rounded-full bg-blue-100 text-brand-blue flex items-center justify-center font-bold text-lg flex-shrink-0">2</div>
                            <h3 class="text-xl font-bold text-gray-800">Recolhimento</h3>
                        </div>
                        <p class="text-gray-600 text-sm md:text-base leading-relaxed">
                            Após 14 dias, retornamos ao lar para recolher o livro e deixar outra mensagem de luz. Aproveitamos para convidar a família a conhecer os trabalhos e cursos do Centro.
                        </p>
                    </div>
                </div>
            </div>

            <!-- CTA -->
            <div class="mt-20 bg-gradient-to-br from-gray-900 to-gray-800 rounded-[3rem] p-12 md:p-16 text-center text-white shadow-2xl relative overflow-hidden">
                <div class="absolute inset-0 bg-brand-blue opacity-20 mix-blend-overlay"></div>
                <div class="relative z-10">
                    <h2 class="text-3xl md:text-5xl font-bold mb-6">Venha ser um Caravaneiro!</h2>
                    <p class="text-lg md:text-xl text-white/90 mb-10 max-w-2xl mx-auto font-light leading-relaxed">
                        Junte-se a nós nesta nobre tarefa de levar o consolo e a luz da Doutrina Espírita aos lares. Sábados de manhã, faça parte desta caravana de amor e esclarecimento.
                    </p>
                    <button id="open-modal-btn" class="inline-flex items-center gap-3 px-10 py-5 bg-white text-gray-800 font-bold text-lg rounded-full hover:bg-gray-100 transition transform hover:-translate-y-1 hover:shadow-xl group">
                        Quero participar
                        <svg class="w-6 h-6 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                    </button>
                </div>
            </div>

        </div>
    </section>

    <!-- Modal Form -->
    <div id="campaign-modal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4 bg-gray-900/60 backdrop-blur-sm opacity-0 transition-opacity duration-300">
        <div class="bg-white rounded-3xl w-full max-w-lg shadow-2xl overflow-hidden transform scale-95 transition-transform duration-300 flex flex-col max-h-[90vh]">
            <div class="flex justify-between items-center p-6 border-b border-gray-100 bg-gray-50">
                <h3 class="text-xl font-bold text-gray-800">Inscrição na Campanha</h3>
                <button id="close-modal-btn" class="text-gray-400 hover:text-gray-600 transition p-2 rounded-full hover:bg-gray-200">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            
            <div class="p-6 overflow-y-auto">
                <form id="campaign-form" class="space-y-5">
                    <input type="hidden" id="campaign-type" name="type" value="CHICO_XAVIER">
                    
                    <div>
                        <label for="name" class="block text-sm font-semibold text-gray-700 mb-1">Nome Completo</label>
                        <input type="text" id="name" name="name" required minlength="3" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-brand-blue focus:border-brand-blue transition outline-none text-gray-700 bg-gray-50 focus:bg-white" placeholder="Seu nome completo">
                    </div>
                    
                    <div>
                        <label for="email" class="block text-sm font-semibold text-gray-700 mb-1">E-mail</label>
                        <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-brand-blue focus:border-brand-blue transition outline-none text-gray-700 bg-gray-50 focus:bg-white" placeholder="seu.email@exemplo.com">
                    </div>
                    
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label for="city" class="block text-sm font-semibold text-gray-700 mb-1">Cidade</label>
                            <input type="text" id="city" name="city" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-brand-blue focus:border-brand-blue transition outline-none text-gray-700 bg-gray-50 focus:bg-white" placeholder="Ex: Uberlândia">
                        </div>
                        <div>
                            <label for="state" class="block text-sm font-semibold text-gray-700 mb-1">Estado</label>
                            <select id="state" name="state" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-brand-blue focus:border-brand-blue transition outline-none text-gray-700 bg-gray-50 focus:bg-white">
                                <option value="" disabled selected>UF</option>
                                <option value="MG">MG</option>
                                <option value="SP">SP</option>
                                <option value="GO">GO</option>
                                <option value="RJ">RJ</option>
                                <option value="OUTRO">Outro</option>
                            </select>
                        </div>
                    </div>

                    <div>
                        <label for="whatsapp" class="block text-sm font-semibold text-gray-700 mb-1">WhatsApp</label>
                        <input type="tel" id="whatsapp" name="whatsapp" required pattern="[0-9 \-\(\)]+" minlength="10" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-brand-blue focus:border-brand-blue transition outline-none text-gray-700 bg-gray-50 focus:bg-white" placeholder="(00) 00000-0000" title="Por favor, inclua o DDD">
                    </div>

                    <div id="form-message" class="hidden text-sm font-semibold p-4 rounded-xl text-center"></div>

                    <button type="submit" id="submit-btn" class="w-full py-4 mt-2 bg-brand-blue text-white rounded-xl font-bold text-lg hover:bg-brand-blueDark transition shadow-lg flex justify-center items-center gap-2">
                        <span id="btn-text">Confirmar Inscrição</span>
                        <svg id="btn-spinner" class="w-5 h-5 animate-spin hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                    </button>
                </form>
            </div>
        </div>
    </div>

    <script>
        const openBtn = document.getElementById('open-modal-btn');
        const closeBtn = document.getElementById('close-modal-btn');
        const modal = document.getElementById('campaign-modal');
        const modalContent = modal.querySelector('div');
        const form = document.getElementById('campaign-form');
        const formMessage = document.getElementById('form-message');
        const submitBtn = document.getElementById('submit-btn');
        const btnText = document.getElementById('btn-text');
        const btnSpinner = document.getElementById('btn-spinner');

        function openModal() {
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            // Slight delay to allow display block to take effect before opacity transition
            setTimeout(() => {
                modal.classList.remove('opacity-0');
                modal.classList.add('opacity-100');
                modalContent.classList.remove('scale-95');
                modalContent.classList.add('scale-100');
            }, 10);
        }

        function closeModal() {
            modal.classList.remove('opacity-100');
            modal.classList.add('opacity-0');
            modalContent.classList.remove('scale-100');
            modalContent.classList.add('scale-95');
            setTimeout(() => {
                modal.classList.remove('flex');
                modal.classList.add('hidden');
            }, 300);
        }

        openBtn.addEventListener('click', openModal);
        closeBtn.addEventListener('click', closeModal);
        modal.addEventListener('click', (e) => {
            if (e.target === modal) closeModal();
        });

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            submitBtn.disabled = true;
            btnText.textContent = 'Enviando...';
            btnSpinner.classList.remove('hidden');
            formMessage.classList.add('hidden');

            const formData = {
                name: document.getElementById('name').value,
                email: document.getElementById('email').value,
                city: document.getElementById('city').value,
                state: document.getElementById('state').value,
                whatsapp: document.getElementById('whatsapp').value,
                type: document.getElementById('campaign-type').value,
            };

            const isLocal = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';
            const API_URL = isLocal 
                ? 'http://127.0.0.1:5001/gept-org-br/us-east1/saveCampaignLeads'
                : 'https://savecampaignleads-fjafv4qsaa-ue.a.run.app';

            try {
                const response = await fetch(API_URL, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(formData)
                });

                if (response.ok) {
                    formMessage.textContent = 'Inscrição confirmada com sucesso! Redirecionando para o WhatsApp...';
                    formMessage.className = 'p-4 rounded-xl text-center text-sm font-semibold bg-green-50 text-green-700 mt-6 block';
                    form.reset();
                    
                    setTimeout(() => {
                        window.open('https://chat.whatsapp.com/CaFqxPmcGa4HnwJm8aCWj0', '_blank');
                    }, 1500);
                } else {
                    const err = await response.json();
                    throw new Error(err.error || 'Erro ao enviar.');
                }
            } catch (error) {
                formMessage.textContent = error.message;
                formMessage.className = 'p-4 rounded-xl text-center text-sm font-semibold bg-red-50 text-red-600 mt-6 block';
            } finally {
                submitBtn.disabled = false;
                btnText.textContent = 'Confirmar Inscrição';
                btnSpinner.classList.add('hidden');
            }
        });
    </script>
</Layout>
